{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlantResponse",
  "description": "植物长势评估响应结构",
  "type": "object",
  "required": ["date", "comparison", "abnormalities", "growth_stage", "key_observations"],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "日期 YYYY-MM-DD"
    },
    "comparison": {
      "type": "object",
      "required": ["trend", "confidence", "evidence"],
      "properties": {
        "trend": {
          "type": "string",
          "enum": ["better", "same", "worse"],
          "description": "长势趋势"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "置信度 0-1"
        },
        "evidence": {
          "type": "string",
          "description": "判断依据"
        }
      }
    },
    "abnormalities": {
      "type": "object",
      "properties": {
        "wilting": {
          "type": ["boolean", "null"],
          "description": "是否萎蔫"
        },
        "yellowing": {
          "type": ["boolean", "null"],
          "description": "是否黄化"
        },
        "pest_damage": {
          "type": ["boolean", "null"],
          "description": "是否有病虫害"
        },
        "other": {
          "type": ["string", "null"],
          "description": "其他异常"
        }
      }
    },
    "growth_stage": {
      "type": "string",
      "enum": ["vegetative", "flowering", "fruiting", "mixed"],
      "description": "生长阶段"
    },
    "key_observations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "maxItems": 5,
      "description": "关键观察点"
    }
  }
}
